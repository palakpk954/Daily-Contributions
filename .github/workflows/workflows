name: Daily Commit

on:
  schedule:
    - cron: "0 18 * * *"
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repo
        uses: actions/checkout@v3

      - name: Update file
        run: |
          echo "Last update: $(date)" >> log.txt

      - name: Commit changes
        run: |
          git config --global user.name "your-github-username"
          git config --global user.email "your-email@example.com"
          git add .
          git commit -m "Daily contribution update" || exit 0
          git push
